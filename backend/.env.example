# Active profile: dev | prod
SPRING_PROFILES_ACTIVE=dev

# Server
SERVER_PORT=8080

# Database (dev defaults to H2; for prod set PostgreSQL values)
# DB_URL=jdbc:postgresql://localhost:5432/edumaterials
# DB_DRIVER=org.postgresql.Driver
# DB_USERNAME=postgres
# DB_PASSWORD=postgres

# JWT (change in production)
JWT_SECRET=change-me-in-production-with-long-random-secret
JWT_EXPIRATION_MS=86400000

# Recommendation settings
RECOMMENDATION_HLOW=0.45
RECOMMENDATION_HHIGH=0.75
RECOMMENDATION_DEFAULT_NORMATIVE_TIME_MS=60000

# H2 console for dev only
H2_CONSOLE_ENABLED=false
